#!/usr/bin/env bash

script_dir="$(dirname "$(realpath "$BASH_SOURCE")")"
export __ff_data_dir="$script_dir/data"
export __ff_db_file="$__ff_data_dir/ff.db"
export __ff_ff_script="$0"

__ff_action() {
  act=$1
  shift 1
  case $act in
  query)
    json=""
    while [[ "$#" -gt 0 ]]; do
      case "$1" in
      -j | --json)
        shift 1
        json="--json"
        ;;
      *)
        break
        ;;
      esac
    done
    sqlite3 $json "$__ff_db_file" "$1"
    ;;
  get-all-projects)
    __ff_action query "select format('%-20s (%s)', name, id) from projects order by last_opened desc" || true
    ;;
  yazi-project)
    cd $(__ff_action get-path-project "$1") 
    tere yazi
    ;;
  sync-db)
    mkdir -p "$__ff_data_dir"
    echo 'create table if not exists projects ( 
  id integer primary key, 
  name text unique not null, 
  path text not null,
  last_opened datetime default 0 
)' | sqlite3 "$__ff_db_file"
    echo "Database synced at $__ff_db_file"
    read -p "Press Enter to continue..."
    ;;
  get-path-project)
    id=$(__ff_action get-project-id "$1")
    __ff_action query "select path from projects where id = $id"
    ;;
  open-project)
    id=$(__ff_action get-project-id "$1")
    dir=$(__ff_action get-path-project "$1")
    __ff_action query "update projects set last_opened = datetime('now', 'localtime') where id = $id"
    cd "$dir" && $EDITOR .
    clear
    ;;
  update-project)
    id=$(__ff_action get-project-id "$1")
    project=$(__ff_action query -j "select path, name from projects where id = $id")
    name=$(echo "$project" | jq -r '.[0].name')
    dir=$(echo "$project" | jq -r '.[0].path')
    new_dir=$(__ff_action yazi-pick-dir "$dir")
    if [[ -d "$new_dir" ]]; then
      echo -n "Path: $new_dir"
      read -p "Enter new name(current: '$name'): " new_name
      new_name="${new_name:-$name}"
      __ff_action query "update projects set path = '$new_dir', name = '$new_name' where id = $id"
    fi
    ;;
  get-project-id)
    line="$1"
    id="${line##*(}"
    id="${id%)}"
    echo "$id"
    ;;
  yazi-pick-dir)
    dir=$(YAZI_CWD="$1" YAZI_TARGET="$1" yazi "$1" --chooser-file=/dev/stdout 2>/dev/null || true)
    if [[ -n "$dir" ]]; then
      echo "$dir"
    fi
    ;;
  preview-project)
    id=$(__ff_action get-project-id "$1")
    project=$(__ff_action query -j "select path, last_opened from projects where id = $id")
    dir=$(echo "$project" | jq -r '.[0].path')
    last_opened=$(echo "$project" | jq -r '.[0].last_opened')

    echo "ID   : $id"
    echo "Path : $dir $([[ ! -d "$dir" ]] && echo -e '\e[31m(not exists)\e[0m')"
    echo "Last Opened: $last_opened"

    zellij ls | grep -P "^(\x1b\[[0-9;]*m)?\Q${dir//\//\\}\E"
    ;;
  new-project)
    dir=$(__ff_action yazi-pick-dir "$HOME")
    if [[ -n "$dir" ]]; then
      echo "$dir"
      read -p "Enter project name: " name
      if [[ -n "$name" ]]; then
        __ff_action query "insert into projects (name, path) values ('$name', '$dir')"
      fi
    fi
    ;;
  delete-project)
    id=$(__ff_action get-project-id "$1")
    gum confirm "Are you sure you want to delete this project? $1" && __ff_action query "delete from projects where id = $id"
    ;;

  esac
}

ff() {
  on_enter="execute(__ff_action open-project {})+clear-query+first+reload(__ff_action get-all-projects)"
  act=project
  binds=""

  case $1 in
  p | project)
    act=project
    ;;
  f | file)
    act=file
    ;;
  s | sync-db)
    shift 1
    rm -f "$__ff_db_file"
    sync-db
    exit
    ;;
  --cd)
    on_enter="become(__ff_action get-path-project {})"
    shift 1
      ;;
  *)
    act=project
    ;;
  esac

  case $act in
  project)
    fzf \
      --preview '__ff_action preview-project {}' \
      --bind "start:reload(__ff_action get-all-projects)" \
      --bind "ctrl-r:reload(__ff_action get-all-projects)+clear-query" \
      --bind "ctrl-space:become($__ff_ff_script)" \
      --bind "ctrl-u:execute(fe)" \
      --bind "ctrl-e:execute(__ff_action update-project {})+reload(__ff_action get-all-projects)" \
      --bind "alt-n:execute(__ff_action yazi-project {})+clear-query" \
      --bind "ctrl-n:execute(__ff_action new-project)+reload(__ff_action get-all-projects)" \
      --bind "ctrl-s:execute(__ff_action sync-db)" \
      --bind "del:execute(__ff_action delete-project {})+reload(__ff_action get-all-projects)" \
      --bind "enter:$on_enter" \
      --bind "esc:clear-query" \
      --bind "ctrl-c:abort" \
      --prompt "Projects ❯ " \
      --reverse --border
    ;;
  esac
}

export -f ff
export -f __ff_action

export SHELL=$(which bash)
ff "$@"
