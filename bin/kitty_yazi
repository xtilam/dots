#!/usr/bin/env bash
echo "$KITTY_LISTEN_ON" | grep -q "kitty-quick-term" && kitten quick-access-terminal && exit 0

socket_id="kitty_yazi_socket.XXXXXX"

while [[ "$#" -gt 0 ]]; do
  case "$1" in
  --client-id | -c)
    client_id="$2"
    shift 2
    ;;
  --socket-id | -s)
    socket_id="$2"
    shift 2
    ;;
  --cwd | -d)
    cwd="$2"
    shift 2
    ;;
  --target | -t)
    target="$2"
    shift 2
    ;;
  *)
    shift 1
    ;;
  esac
done

socket=$(mktemp -u "/tmp/$socket_id")

if [[ -z "$cwd" ]]; then
  cwd=$(pwd)
fi

if [[ -z "$target" ]]; then
  target="$cwd"
fi

yazi_task() {
  rs_socket="$1"
  cleanup() {
    echo "" | nc -U "$rs_socket"
  }
  if [[ "$(kitty @ ls | jq "[.[] | .is_focused ][0]")" == "false" ]]; then
    kitten quick-access-terminal
  fi

  trap cleanup SIGINT SIGTERM EXIT
  cd $2
  file=$(YAZI_TARGET="$3" YAZI_CWD="$2" yazi --chooser-file=/dev/stdout $([[ -n "$4" ]] && echo "--client-id $4") $3)
  echo "$file" | nc -U "$rs_socket"
  kitten quick-access-terminal
  trap - SIGINT SIGTERM EXIT
}

handle_request() {
  if [[ -n "$1" ]]; then
    echo $1
    exit 0
  else
    exit 1
  fi
}

while true; do
  quick_term=$(fd kitty-quick-term /tmp)
  if [[ -n "$quick_term" ]]; then
    break
  fi
  kitten quick-access-terminal --detach
  sleep 0.1
done

kitty_remote="unix:$quick_term"
code="$(declare -f yazi_task);"'yazi_task $1 $2 $3 $4'
window_id=$(kitty @ launch --type=overlay --to="$kitty_remote" bash -c "$code" -- "$socket" "$cwd" "$target" "$client_id")

while read -r line; do
  handle_request "$line"
done < <(nc -lU "$socket" 2>/dev/null)
